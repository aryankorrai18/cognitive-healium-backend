# Copy this to .env and fill in your values
# Never commit .env to git

# Required: Groq API keys (comma-separated for round-robin rotation)
GROQ_API_KEYS=gsk_your_key_here,gsk_your_second_key_here

# Optional: tenant ID for ChromaDB collection isolation
TENANT_ID=team_virtusa

# Optional: set these to use Redis, Postgres, and S3 instead of local defaults
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://healium:healium_dev@localhost:5432/healium
# S3_BUCKET=your-bucket-name

# Optional: set these to use a remote ChromaDB instance
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# Optional: Docker Postgres password (used in docker-compose.yml)
# DB_PASSWORD=healium_dev
